{
  "name": "dotns-ui",
  "version": "0.6.7",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.2.6",
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vue-tsc --noEmit -p tsconfig.app.json && bunx vite build",
    "preview": "bunx vite preview",
    "lint": "bunx eslint \"src/**/*.{ts,vue}\" --max-warnings=0",
    "lint:fix": "bunx eslint \"src/**/*.{ts,vue}\" --fix",
    "format": "bunx prettier --check \"src/**/*.{ts,vue,js,json,css,scss,html,md}\"",
    "format:fix": "bunx prettier --write \"src/**/*.{ts,vue,js,json,css,scss,html,md}\" \"!abis/**\"",
    "typecheck": "bunx vue-tsc --noEmit -p tsconfig.app.json",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "lint:format": "bun run lint && bun run format",
    "lint:format:fix": "bun run lint:fix && bun run format:fix"
  },
  "dependencies": {
    "@dedot/chaintypes": "^0.187.0",
    "@ipld/dag-pb": "^4.1.5",
    "@noble/hashes": "^2.0.1",
    "@parity/product-sdk": "^0.10.0",
    "@parity/product-sdk-address": "^0.1.1",
    "@parity/product-sdk-chain-client": "^0.6.0",
    "@parity/product-sdk-contracts": "^0.7.1",
    "@parity/product-sdk-descriptors": "^0.5.2",
    "@parity/product-sdk-host": "^0.7.0",
    "@parity/product-sdk-signer": "^0.6.1",
    "@parity/product-sdk-tx": "^0.2.8",
    "@parity/product-sdk-utils": "^0.1.1",
    "@polkadot-api/json-rpc-provider": "^0.2.0",
    "@polkadot-api/metadata-builders": "^0.14.2",
    "@polkadot-api/substrate-bindings": "^0.20.2",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clear": "^0.1.0",
    "clsx": "^2.1.1",
    "ethereum-blockies-base64": "^1.0.2",
    "ipfs-unixfs": "^12.0.0",
    "multiformats": "^13.4.2",
    "pinia": "^2.1.4",
    "polkadot-api": "^2.1.5",
    "shiki": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "viem": "^2.45.0",
    "vue": "^3.5.27",
    "vue-router": "^4.0.3",
    "vue-toastification": "^2.0.0-rc.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.16",
    "@types/node": "^24.10.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/cli-plugin-router": "~5.0.9",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.5.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "rollup": "^4.52.5",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue-cli-plugin-pinia": "~0.2.4",
    "vue-tsc": "^3.1.0",
    "wrangler": "^4.47.0"
  }
}