{
  "name": "dotns-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.6",
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vue-tsc --noEmit -p tsconfig.app.json && bunx vite build",
    "preview": "bunx vite preview",
    "lint": "bunx eslint \"src/**/*.{ts,vue}\" --max-warnings=0",
    "lint:fix": "bunx eslint \"src/**/*.{ts,vue}\" --fix",
    "format": "bunx prettier --check \"src/**/*.{ts,vue,js,json,css,scss,html,md}\"",
    "format:fix": "bunx prettier --write \"src/**/*.{ts,vue,js,json,css,scss,html,md}\" \"!abis/**\"",
    "typecheck": "bunx vue-tsc --noEmit -p tsconfig.app.json",
    "lint:format": "bun run lint && bun run format",
    "lint:format:fix": "bun run lint:fix && bun run format:fix",
    "postinstall": "bunx papi"
  },
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@dedot/chaintypes": "^0.187.0",
    "@helia/unixfs": "^7.1.0",
    "@ipld/dag-pb": "^4.1.5",
    "@libp2p/websockets": "^10.1.6",
    "@multiformats/blake2": "^2.0.2",
    "@multiformats/multiaddr": "^13.0.1",
    "@noble/hashes": "^2.0.1",
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "@polkadot-api/sdk-ink": "^0.5.1",
    "@polkadot-api/substrate-bindings": "^0.17.0",
    "@polkadot/api": "16.5.4",
    "@polkadot/api-contract": "^16.5.4",
    "@polkadot/extension-dapp": "^0.62.3",
    "@polkadot/keyring": "^13.5.4",
    "@polkadot/rpc-augment": "16.5.4",
    "@polkadot/rpc-core": "16.5.4",
    "@polkadot/rpc-provider": "16.5.4",
    "@polkadot/types": "16.5.4",
    "@polkadot/types-codec": "16.5.4",
    "@polkadot/types-create": "16.5.4",
    "@polkadot/types-known": "16.5.4",
    "@talismn/connect-wallets": "^1.2.8",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clear": "^0.1.0",
    "clsx": "^2.1.1",
    "ethereum-blockies-base64": "^1.0.2",
    "helia": "^6.0.22",
    "ipfs-unixfs": "^12.0.0",
    "multiformats": "^13.4.2",
    "pinia": "^2.1.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "polkadot-api": "^1.23.3",
    "shiki": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "viem": "^2.45.0",
    "vue": "^3.5.27",
    "vue-router": "^4.0.3",
    "vue-toastification": "^2.0.0-rc.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.16",
    "@types/node": "^24.10.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/cli-plugin-router": "~5.0.9",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.5.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "rollup": "^4.52.5",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue-cli-plugin-pinia": "~0.2.4",
    "vue-tsc": "^3.1.0",
    "wrangler": "^4.47.0"
  }
}